#!/usr/bin/env sh

# Block tag pushes unless release:verify passes.
# Git feeds pushed refs to stdin: "<local-ref> <local-sha> <remote-ref> <remote-sha>"

pushing_tag=false
while read local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/tags/*) pushing_tag=true ;;
  esac
done

if [ "$pushing_tag" = true ]; then
  echo ""
  echo "Tag push detected — running release:verify before allowing publish..."
  echo ""
  pnpm release:verify
  if [ $? -ne 0 ]; then
    echo ""
    echo "release:verify failed. Fix the errors above before pushing this tag."
    echo ""
    exit 1
  fi
  echo ""
  echo "release:verify passed. Pushing tag."
  echo ""
fi
