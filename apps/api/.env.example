# Local development only.
# Railway should own deployed API runtime envs.
# Keep live secrets out of this file.
# If you run multiple local starter copies, keep these localhost ports aligned
# with the host port overrides in the root .env file used by docker compose.

PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5433/acme_platform
# Optional local override for Drizzle generation and migration commands.
# Leave blank to reuse DATABASE_URL.
DATABASE_MIGRATION_URL=
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=no-reboot-hq
FEATURE_FLAGS_JSON=
KAFKA_BROKERS=localhost:19092
CONFIG_EVENTS_TOPIC=config.events
CONFIG_ENCRYPTION_KEY=local-config-encryption-key-32-bytes
CONFIG_TOKEN_PEPPER=local-config-token-pepper-32-bytes
CONFIG_OUTBOX_PUBLISH_INTERVAL_MS=5000
APP_ORIGIN=http://localhost:3000
API_CORS_ORIGIN=http://localhost:3000
BETTER_AUTH_SECRET=local-dev-better-auth-secret-32-bytes
BETTER_AUTH_URL=http://localhost:3000
AUTH_FROM_EMAIL=No Reboot HQ <auth@no-reboot-hq.local>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
API_SERVICE_NAME=no-reboot-hq-api
API_SENTRY_DSN=
API_LOG_LEVEL=info
API_LOG_TO_LOKI=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOKI_URL=http://localhost:3100
