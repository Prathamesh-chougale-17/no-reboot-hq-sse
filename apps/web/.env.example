# Local development only.
# Vercel should own deployed web runtime envs.
# Keep live secrets out of this file.
# If you run multiple local starter copies, keep these localhost ports aligned
# with the host port overrides in the root .env file used by docker compose.

NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_UPSTREAM_URL=http://localhost:3001
NEXT_PUBLIC_SENTRY_DSN=
BETTER_AUTH_SECRET=local-dev-better-auth-secret-32-bytes
BETTER_AUTH_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=no-reboot-hq
FEATURE_FLAGS_JSON=
AUTH_FROM_EMAIL=No Reboot HQ <auth@no-reboot-hq.local>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
